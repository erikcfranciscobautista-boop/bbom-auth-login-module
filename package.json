{
  "name": "@uuaa/bbom-auth-login-module",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./dist/*": "./dist/src/*",
    "./*": "./dist/src/*"
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "prepare": "npm run build",
    "prepack": "npm run build",
    "start:test": "node dist/scripts/run-local.js",
    "start:test:dev": "node --loader ts-node/esm scripts/run-local.ts",
    "build": "tsc -p .",
    "test:unit": "TS_NODE_PROJECT=tsconfig.test.json node --loader ts-node/esm --test test/**/*.test.ts",
    "scaffold:module": "node --loader ts-node/esm scripts/scaffold-module.ts",
    "docker:local": "docker compose up --build bbom-auth-login-module",
    "docker:test:unit": "docker compose --profile test run --rm bbom-auth-login-tests"
  },
  "dependencies": {
    "fastify": "^4.24.0",
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "@types/node": "^20.4.2",
    "@types/jsonwebtoken": "^9.0.2"
  }
}