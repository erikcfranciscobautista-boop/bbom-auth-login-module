{
  "name": "@uuaas-bbom/bbom-auth-login",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start:test:dev": "node --loader ts-node/esm test/scripts/run-local.ts",
    "prepare": "node -e \"if(require('fs').existsSync('src')) require('child_process').execSync('npm run build')\""
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "zod": "^3.22.2"
  },
  "devDependencies": {
    "fastify": "^4.24.0",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "@types/node": "^20.4.2",
    "@types/jsonwebtoken": "^9.0.2"
  }
}